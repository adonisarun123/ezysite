# Always install devDependencies, even when NODE_ENV=production is present in
# the environment. Without this, `npm install` under NODE_ENV=production silently
# omits devDependencies (TypeScript types, build tooling, CSS pipeline), which
# breaks `next dev` (globals.css "Unexpected character '@'") and `next build`
# (missing @types/* declaration files).
omit=
include=dev
