# ===================
# Required Variables
# ===================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only: required for /on-demand-help booking overlap + reservation (never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SMTP Email Configuration
# For Gmail: Use App Password (https://support.google.com/accounts/answer/185833)
# For SendGrid: Use API key as password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email Recipients (comma-separated list)
# Default recipients for agent/helper registration and other forms.
# NOTE (June 2026): contact@, priyanka@, arun@ and suraj@ are ALWAYS added in code
# (lib/emailService.ts ALWAYS_CC_EMAILS) on every email, regardless of these vars.
EMAIL_RECIPIENTS=contact@ezyhelpers.com,priyanka@ezyhelpers.com,arun@ezyhelpers.com,suraj@ezyhelpers.com
ADMIN_EMAIL=contact@ezyhelpers.com

# Hire Helper & Contact Form Recipients (comma-separated list)
# These emails receive leads from /hire-helper and /contact pages only
# Example: contact@ezyhelpers.com,suraj.ezyhelpers@gmail.com,ashma@ezyhelpers.com
HIRE_CONTACT_EMAIL_RECIPIENTS=contact@ezyhelpers.com,suraj.ezyhelpers@gmail.com

# Customer Requirement Form Recipients
CUSTOMER_REQUIREMENT_RECIPIENTS=arun@ezyhelpers.com,suraj@ezyhelpers.com,priyanka@ezyhelpers.com

# Bangalore care services enquiry (/care-services/enquiry)
CARE_SERVICES_EMAIL_RECIPIENTS=contact@ezyhelpers.com,arun@ezyhelpers.com,suraj@ezyhelpers.com
# Caregiver/nursing candidate applications (/care-services/apply — Facebook ads)
CANDIDATE_APPLICATION_RECIPIENTS=contact@ezyhelpers.com,arun@ezyhelpers.com,suraj@ezyhelpers.com,ankit@ezyhelpers.com,priyanka@ezyhelpers.com

# Anthropic API Key (for the AI chatbot assistant "Asha" + lead triage)
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# AI lead triage (lib/leadTriage.ts): prepends urgency/summary to lead emails.
# Runs automatically when ANTHROPIC_API_KEY is set. Set to 'true' to turn off.
# LEAD_TRIAGE_DISABLED=true

# Chatbot lead email recipients. The core team (contact@, priyanka@, arun@,
# suraj@) is ALWAYS added in code regardless of this var.
LEAD_TO=contact@ezyhelpers.com,priyanka@ezyhelpers.com,arun@ezyhelpers.com,suraj@ezyhelpers.com
# Chat transcript recipients (defaults to LEAD_TO + ankit@; the 5-person list
# below is always added in code regardless of this var)
TRANSCRIPT_TO=contact@ezyhelpers.com,priyanka@ezyhelpers.com,arun@ezyhelpers.com,suraj@ezyhelpers.com,ankit@ezyhelpers.com

# API Security
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=generate-a-secure-random-32-character-key-here

# Node Environment
NODE_ENV=development

# ===================
# Optional Variables
# ===================

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-868JRCDRFW
# NEXT_PUBLIC_CLARITY_ID=your-clarity-id
# NEXT_PUBLIC_FB_PIXEL_ID=1223380436207834

# Public Site Information (Optional)
# NEXT_PUBLIC_SITE_URL=https://ezyhelpers.com
# NEXT_PUBLIC_PHONE=+919972571005
# NEXT_PUBLIC_EMAIL=contact@ezyhelpers.com

# Local PDF generation (app/api/generate-pdf): path to a local Chrome/Chromium binary.
# Not needed on Vercel/Lambda (uses @sparticuz/chromium automatically).
# macOS example: PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
PUPPETEER_EXECUTABLE_PATH=
