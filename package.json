{
  "name": "ezyhelpers-website",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/adonisarun123/ezysite.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "type-check": "tsc --noEmit",
    "analyze-bundle": "node scripts/analyze-bundle.js",
    "optimize-css": "node scripts/optimize-css.js",
    "optimize-performance": "node scripts/optimize-performance.js",
    "build:optimized": "npm run optimize-performance && npm run build",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "validate-sitemap": "curl -s http://localhost:3000/sitemap.xml | head -10"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.0.18",
    "@playwright/test": "^1.53.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/supabase-js": "2.50.0",
    "@types/puppeteer": "^7.0.4",
    "autoprefixer": "^10.4.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "libphonenumber-js": "^1.12.24",
    "lucide-react": "^0.577.0",
    "next": "^15.5.14",
    "nodemailer": "^8.0.4",
    "p-retry": "^7.1.0",
    "postcss": "^8.4.32",
    "puppeteer": "^24.13.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.8.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.48.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/ui": "^3.2.4",
    "critters": "^0.0.25",
    "eslint": "^8.55.0",
    "eslint-config-next": "14.0.4",
    "glob": "^10.3.10",
    "jsdom": "^27.0.1",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
