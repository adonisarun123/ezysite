# Production Environment Configuration
NODE_ENV=production

# Production Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-prod-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-prod-anon-key

# Production SMTP (SendGrid recommended)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key

# Production Email Recipients
# Default recipients for agent/helper registration and other forms.
# NOTE (June 2026): contact@, priyanka@, arun@ and suraj@ are ALWAYS added in code
# (lib/emailService.ts ALWAYS_CC_EMAILS) on every email, regardless of these vars.
EMAIL_RECIPIENTS=contact@ezyhelpers.com,priyanka@ezyhelpers.com,arun@ezyhelpers.com,suraj@ezyhelpers.com
ADMIN_EMAIL=contact@ezyhelpers.com

# Hire Helper & Contact Form Recipients (Production)
# These emails receive leads from /hire-helper and /contact pages only
HIRE_CONTACT_EMAIL_RECIPIENTS=contact@ezyhelpers.com,suraj.ezyhelpers@gmail.com

# Anthropic API Key (for the AI chatbot assistant "Asha")
ANTHROPIC_API_KEY=sk-ant-your-production-key

# Chatbot lead email recipients (core team always added in code)
LEAD_TO=contact@ezyhelpers.com,priyanka@ezyhelpers.com,arun@ezyhelpers.com,suraj@ezyhelpers.com
# Chat transcript recipients (5-person list always added in code)
TRANSCRIPT_TO=contact@ezyhelpers.com,priyanka@ezyhelpers.com,arun@ezyhelpers.com,suraj@ezyhelpers.com,ankit@ezyhelpers.com

# Production API Security
# MUST be 32+ characters, randomly generated
API_SECRET_KEY=generate-with-crypto-randomBytes-32-hex

# Error Monitoring (Production)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Analytics (Production)
NEXT_PUBLIC_GA_ID=G-868JRCDRFW
NEXT_PUBLIC_CLARITY_ID=your-clarity-id
NEXT_PUBLIC_FB_PIXEL_ID=1223380436207834

# Logging (Production)
LOG_LEVEL=WARN
